PROGRAMA TestSaltarControlado

    VARIABLE ENTERA $contador = 0
    VARIABLE ENTERA $limite = 10

BLOQUE PRINCIPAL
    ETIQUETA inicio

    MOSTRAR ("Iteración: $contador") SALTO
    CALCULAR EN $contador = $contador + 1

    SI ($contador MENOR $limite) ENTONCES
        SALTAR A inicio
    FIN SI

    MOSTRAR ("Fin del bucle.") SALTO
FIN PRINCIPAL
FINAL
