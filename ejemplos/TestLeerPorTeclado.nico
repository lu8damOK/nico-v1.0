PROGRAMA TestLeerConPrompt

    VARIABLE ENTERA $numero = 0
    VARIABLE TEXTO $nombre = ""
    VARIABLE CARACTER $letra = 'A'
    
BLOQUE PRINCIPAL
    LIMPIARPANTALLA

    ESCRIBIR("Ingrese su nombre: ")
    LEER($nombre)
    ESCRIBIR("Ingrese su número: ")
    LEER($numero)
    ESCRIBIR("Ingrese una letra: ") 
    LEERCARACTER($letra)

    ESCRIBIR("Hola $nombre, tu número es [$numero + 10], letra: $letra") SALTO

FIN PRINCIPAL
FINAL
